# Tastytrade OAuth credentials (required for live/dry-run, not needed for paper)
TT_SECRET=your_provider_secret_here
TT_REFRESH=your_refresh_token_here

# Optional: specify account number (uses first account if not set)
TT_ACCOUNT=

# Paper mode: walk-forward using yfinance only, fills at theo mid, $1/contract comms
PAPER_MODE=true

# Safety: set to false to place real orders (default: true, ignored in paper mode)
DRY_RUN=true

# Database path (default: strategy.db)
DB_PATH=strategy.db
